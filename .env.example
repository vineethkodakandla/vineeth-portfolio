# ════════════════════════════════════════════════════════════════════════
#  Every external service below is feature-detected at runtime. If a key is
#  missing, that feature degrades gracefully — the app still builds and runs.
#  Only ANTHROPIC_API_KEY is load-bearing (the chatbot's answers).
# ════════════════════════════════════════════════════════════════════════

# ── Required: powers the chatbot's answers ──────────────────────────────
# https://console.anthropic.com  → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Optional model override. Haiku is fast + cheap (good default for a public bot).
CHAT_MODEL=claude-haiku-4-5-20251001

# ── Database: Neon Postgres + pgvector (RAG vectors + dynamic data) ──────
# https://neon.tech  → create project → copy the POOLED connection string.
# Missing → RAG falls back to the bundled JSON (full-context); contact still
# emails (not persisted); analytics no-op.
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require

# ── Embeddings: Voyage (enables true vector retrieval) ──────────────────
# https://www.voyageai.com  → API Keys. Free tier available.
# Missing → full-context mode (no per-query retrieval).
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-lite

# ── Redis: Upstash (durable rate limiting, caching, view counters) ──────
# https://upstash.com  → create Redis DB → REST URL + token.
# Missing → falls back to an in-memory rate limiter; counts read from Postgres.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Email: Resend (contact-form notifications) ──────────────────────────
# https://resend.com  → API key + verify a sending domain/sender.
# Missing → submissions are persisted to Postgres but no email is sent.
RESEND_API_KEY=
CONTACT_TO_EMAIL=vineethkodakandla@gmail.com
CONTACT_FROM_EMAIL=onboarding@resend.dev

# ── Error monitoring: Sentry (optional) ─────────────────────────────────
# https://sentry.io  → create a Next.js project.
# Missing → Sentry init is a no-op; the app still builds and runs.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── SEO / metadata ──────────────────────────────────────────────────────
# Used for canonical URLs, sitemap, robots, OpenGraph images.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Metrics endpoint guard ──────────────────────────────────────────────
# Bearer token required to read /api/metrics. Missing → endpoint returns 401.
METRICS_TOKEN=
